{
  "properties": {
    "displayName": "Deploy Defender Onboarding Pre-requisites to Windows VMs using CSE",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Deploys Defender Onboarding Pre-requisites script to Windows VMs via Custom Script Extension to execute a Powershell script using UAMI.",
    "metadata": {
      "category": "Compute",
      "createdBy": "ea78ccd1-4b49-4305-9397-d8b8197ea48b",
      "createdOn": "2026-06-24T17:34:54.1126192",
      "updatedBy": "ea78ccd1-4b49-4305-9397-d8b8197ea48b",
      "updatedOn": "2026-06-24T19:40:20.6833741Z"
    },
    "version": "1.0.0",
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect"
        },
        "allowedValues": [
          "DeployIfNotExists",
          "Disabled"
        ],
        "defaultValue": "DeployIfNotExists"
      },
      "uamiClientId": {
        "type": "String",
        "metadata": {
          "displayName": "User Assigned Managed Identity Client ID"
        }
      },
      "forceUpdateTag": {
        "type": "String",
        "metadata": {
          "displayName": "Tag used for versioning and CSE compliance validation"
        },
        "defaultValue": "DefenderOnboarding-v1"
      },
      "scriptUri": {
        "type": "String",
        "metadata": {
          "displayName": "Script URI"
        }
      },
      "commandToExecute": {
        "type": "String",
        "metadata": {
          "displayName": "Command To Execute"
        },
        "defaultValue": "powershell.exe -ExecutionPolicy Bypass -NoProfile -File Defender-Onboarding.ps1"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType",
            "equals": "Windows"
          },
          {
            "anyOf": [
              {
                "field": "tags['DefenderOnboarding']",
                "exists": "false"
              },
              {
                "field": "tags['DefenderOnboarding']",
                "notEquals": "false"
              }
            ]
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "type": "Microsoft.Compute/virtualMachines/extensions",
          "name": "[concat(field('name'), '/DefenderOnboardingCSE')]",
          "evaluationDelay": "AfterProvisioningSuccess",
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
          ],
          "existenceCondition": {
            "allOf": [
              {
                "field": "Microsoft.Compute/virtualMachines/extensions/type",
                "equals": "CustomScriptExtension"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/extensions/publisher",
                "equals": "Microsoft.Compute"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/extensions/provisioningState",
                "equals": "Succeeded"
              },
              {
                "field": "Microsoft.Compute/virtualMachines/extensions/forceUpdateTag",
                "equals": "[parameters('forceUpdateTag')]"
              }
            ]
          },
          "deployment": {
            "properties": {
              "mode": "incremental",
              "parameters": {
                "vmName": {
                  "value": "[field('name')]"
                },
                "location": {
                  "value": "[field('location')]"
                },
                "uamiClientId": {
                  "value": "[parameters('uamiClientId')]"
                },
                "scriptUri": {
                  "value": "[parameters('scriptUri')]"
                },
                "commandToExecute": {
                  "value": "[parameters('commandToExecute')]"
                }
              },
              "template": {
                "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                "contentVersion": "1.0.0.0",
                "parameters": {
                  "vmName": {
                    "type": "string"
                  },
                  "location": {
                    "type": "string"
                  },
                  "uamiClientId": {
                    "type": "string"
                  },
                  "scriptUri": {
                    "type": "string"
                  },
                  "commandToExecute": {
                    "type": "string"
                  }
                },
                "resources": [
                  {
                    "type": "Microsoft.Compute/virtualMachines/extensions",
                    "apiVersion": "2023-09-01",
                    "name": "[concat(parameters('vmName'), '/DefenderOnboardingCSE')]",
                    "location": "[parameters('location')]",
                    "properties": {
                      "publisher": "Microsoft.Compute",
                      "type": "CustomScriptExtension",
                      "typeHandlerVersion": "1.10",
                      "autoUpgradeMinorVersion": true,
                      "forceUpdateTag": "1",
                      "protectedSettings": {
                        "managedIdentity": {
                          "clientId": "[parameters('uamiClientId')]"
                        },
                        "fileUris": [
                          "[parameters('scriptUri')]"
                        ],
                        "commandToExecute": "[parameters('commandToExecute')]"
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "versions": [
      "1.0.0"
    ]
  },
  "id": "/subscriptions/fa7b0278-0659-4cc0-8909-9827c3bc3763/providers/Microsoft.Authorization/policyDefinitions/0d89f4ac95584e8c80f49b22",
  "type": "Microsoft.Authorization/policyDefinitions",
  "name": "0d89f4ac95584e8c80f49b22",
  "systemData": {
    "lastModifiedByType": "User",
    "lastModifiedAt": "2026-06-24T19:40:20.6155293Z"
  }
}
